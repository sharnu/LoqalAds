---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import ContactCard from '../components/ContactCard.astro';
import { site } from '../data/site';

const next = [
  'A 30–60 minute discovery call to understand your problem, context, and goals.',
  'A written proposal within one week — approach, timeline, deliverables, team, and pricing.',
  'Kick-off within days, with the same senior engineers who will deliver the work.',
];
---

<BaseLayout
  title="Contact"
  description="Talk to LoqalAds. Reach us directly by email, phone, or WhatsApp to start a free, no-obligation discovery conversation, or to see a VillaDesk demo."
>
  <PageHeader
    eyebrow="Get in touch"
    title="Let's talk."
    intro="If you are evaluating partners for a new build, a modernization, an AI initiative, or anything in between — we would welcome a conversation. Reach us directly; you will be talking to engineers, not a sales desk."
  />

  <Section>
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-7">
        <h2 class="text-2xl">Reach us directly</h2>
        <p class="mt-3 text-slate-600">
          Email, call, or message us on WhatsApp — whichever suits you. We respond personally.
        </p>
        <div class="mt-8 space-y-4">
          <ContactCard
            href={`mailto:${site.email}`}
            label="Email"
            value={site.email}
            note="Best for project briefs and detailed questions."
            accent="#7C3AED"
          >
            <svg
              slot="icon"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3 7 9 6 9-6"></path>
            </svg>
          </ContactCard>

          <ContactCard
            href={`tel:${site.phoneRaw}`}
            label="Phone"
            value={site.phone}
            note="Best for a quick conversation during business hours."
            accent="#2563EB"
          >
            <svg
              slot="icon"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"
              ></path>
            </svg>
          </ContactCard>

          <ContactCard
            href={site.whatsapp}
            label="WhatsApp"
            value="Message us on WhatsApp"
            note="Best for a fast, informal first hello."
            external={true}
            accent="#059669"
          >
            <svg slot="icon" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.372-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.002-5.45 4.437-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413"
              ></path>
            </svg>
          </ContactCard>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="rounded-2xl bg-ink p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
            What happens next
          </p>
          <ol class="mt-6 space-y-5">
            {
              next.map((step, i) => (
                <li class="flex gap-4">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-accent font-display text-xs font-semibold text-white">
                    {i + 1}
                  </span>
                  <span class="text-sm leading-6 text-slate-300">{step}</span>
                </li>
              ))
            }
          </ol>
          <p class="mt-8 border-t border-white/10 pt-6 text-sm leading-6 text-slate-400">
            Thank you for considering us. We look forward to building something excellent with you.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section tone="mist" class="border-t border-line">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm leading-6 text-slate-500">
        <span class="font-semibold text-ink">{site.legalName}</span> &middot; {site.location}
      </p>
    </div>
  </Section>
</BaseLayout>
