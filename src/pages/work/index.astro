---
import { getCollection } from 'astro:content';
import { spectrum } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Section from '../../components/Section.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTABand from '../../components/CTABand.astro';

const studies = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Work"
  description="Products and client work from LoqalAds — from our own VillaDesk platform to websites and cloud systems we have designed, built, and shipped."
>
  <PageHeader
    eyebrow="Our work"
    title="Products and sites in production."
    intro="From our own product, VillaDesk, to websites and cloud platforms built for clients — a sample of what LoqalAds designs, builds, and ships. Further references are available on request."
  />

  <Section>
    <div class="grid gap-6 lg:grid-cols-2">
      {
        studies.map((study, i) => (
          <CaseStudyCard
            href={`/work/${study.slug}`}
            service={study.data.service}
            title={study.data.title}
            client={study.data.client}
            summary={study.data.summary}
            outcomes={study.data.outcomes}
            accent={spectrum[i % spectrum.length]}
          />
        ))
      }
    </div>
    <p class="mt-10 text-sm text-slate-500">
      Please contact us to discuss case studies relevant to your industry and problem domain.
    </p>
  </Section>

  <CTABand />
</BaseLayout>
