---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import CTABand from '../../components/CTABand.astro';

export async function getStaticPaths() {
  const studies = await getCollection('work');
  return studies.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
---

<BaseLayout title={d.title} description={d.summary}>
  <section class="border-b border-line bg-mist">
    <div class="wrap py-16 sm:py-20">
      <a href="/work" class="text-sm font-semibold text-accent">&larr; All work</a>
      <p class="eyebrow mt-6">{d.service}</p>
      <h1 class="mt-3 max-w-3xl text-3xl leading-tight sm:text-4xl">{d.title}</h1>
      <p class="mt-4 text-lg font-medium text-ink">{d.client}</p>
      <p class="mt-2 max-w-2xl text-[15px] leading-7 text-slate-600">{d.clientDescription}</p>
    </div>
  </section>

  <Section>
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <article class="prose-content lg:col-span-7">
        <Content />
      </article>

      <aside class="lg:col-span-5">
        <div class="lg:sticky lg:top-24">
          <div class="rounded-xl border border-line bg-white p-7 shadow-card">
            <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-ink">
              Outcomes
            </h2>
            <ul class="mt-4 space-y-3">
              {
                d.outcomes.map((o) => (
                  <li class="flex gap-3 text-[15px] font-medium leading-6 text-ink">
                    <svg
                      class="mt-0.5 h-4 w-4 shrink-0 text-accent"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 1 1 1.4-1.4l2.8 2.8 6.8-6.8a1 1 0 0 1 1.4 0Z" />
                    </svg>
                    <span>{o}</span>
                  </li>
                ))
              }
            </ul>

            <h2 class="mt-7 text-sm font-semibold uppercase tracking-[0.14em] text-ink">
              Stack & focus
            </h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {
                d.tags.map((tag) => (
                  <span class="rounded-md bg-mist px-2.5 py-1 text-xs font-medium text-slate-600">
                    {tag}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </aside>
    </div>
  </Section>

  <CTABand
    title="Have a problem like this?"
    text="Tell us about it. Every engagement starts with a free discovery conversation."
  />
</BaseLayout>
