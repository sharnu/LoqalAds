---
import { getCollection } from 'astro:content';
import { spectrum, site, products } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import StatStrip from '../components/StatStrip.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import CTABand from '../components/CTABand.astro';

const studies = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const villadesk = products[0];

const villadeskFeatures = [
  'WhatsApp confirmations, reminders & review requests from your own number',
  'UPI payment links for faster advances and balance collection',
  'A 10-stage booking pipeline so no enquiry goes cold',
  'iCal sync with Airbnb & Booking.com, plus GST invoicing',
];

const services = [
  {
    title: 'Custom software development',
    text: 'Full-stack web applications, real-time systems, and event-driven architectures, built to last.',
  },
  {
    title: 'Website design & development',
    text: 'Fast, mobile-first, SEO-ready websites that convert — the same craft behind LonavillaStay and Altivision.',
  },
  {
    title: 'Cloud-native architecture',
    text: 'Cloud-native development, infrastructure-as-code, and reliable, automated delivery.',
  },
  {
    title: 'Data, AI & ML',
    text: 'Data pipelines, analytics platforms, and machine learning from prototype to production.',
  },
  {
    title: 'Enterprise modernization',
    text: 'Legacy re-platforming, incremental migration, and API-led integration.',
  },
  {
    title: 'Support & maintenance',
    text: 'SLA-backed monitoring, patching, and performance tuning for systems already in production.',
  },
];

const stats = [
  { value: '2', label: 'Live products & platforms' },
  { value: '14–25 yrs', label: 'Experience per engineer' },
  { value: '3+', label: 'Sites & apps in production' },
  { value: 'Pune', label: 'Built in India' },
];
---

<BaseLayout
  title="LoqalAds"
  description="LoqalAds Media Private Limited is a Pune-based software company. We build our own products — like VillaDesk — and deliver custom software, web, cloud, and AI services, end-to-end."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-line bg-white">
    <div
      class="absolute left-1/2 top-0 h-72 w-[680px] -translate-x-1/2 rounded-full bg-spectrum opacity-[0.12] blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="wrap relative py-16 text-center sm:py-20 lg:py-24">
      <span class="inline-flex items-center gap-2.5 text-xs font-bold uppercase tracking-[0.16em]">
        <span class="h-[2px] w-6 rounded-full bg-spectrum"></span>
        <span class="text-spectrum">Software company · {site.location}</span>
        <span class="h-[2px] w-6 rounded-full bg-spectrum"></span>
      </span>
      <h1 class="mx-auto mt-5 max-w-4xl text-4xl leading-[1.08] sm:text-5xl lg:text-6xl">
        Software <span class="text-spectrum">products & services,</span> built to ship.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        LoqalAds Media Pvt Ltd builds its own products &mdash; like VillaDesk &mdash; and delivers
        custom software, web, cloud, and AI for clients who cannot afford to get it wrong.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/products">Explore our products</Button>
        <Button href="/services" variant="secondary">See our services</Button>
      </div>
      <p class="mt-8 text-sm font-medium text-slate-500">
        Senior team &middot; Full-lifecycle ownership &middot; Based in Pune, working worldwide
      </p>
    </div>
  </section>

  <!-- Two pillars -->
  <Section tone="mist">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow justify-center">What we do</p>
      <h2 class="mt-3 text-3xl sm:text-4xl">Two ways we create value.</h2>
      <p class="mt-4 text-slate-600">
        We invest in products of our own, and we put the same senior engineering to work for
        clients as a service.
      </p>
    </div>
    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      <Card accent={spectrum[1]}>
        <span
          class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.12em]"
          style={`background-color:${spectrum[1]}1F;color:${spectrum[1]}`}
        >
          Products
        </span>
        <h3 class="mt-4 text-2xl">Software we build and run.</h3>
        <p class="mt-3 text-[15px] leading-7 text-slate-600">
          Our flagship product, <strong>VillaDesk</strong>, is a WhatsApp-assisted guest CRM for
          independent villa and homestay owners in India &mdash; helping them run a single villa
          like a hotel chain.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={villadesk.href} variant="secondary">Explore VillaDesk</Button>
          <Button href={villadesk.external} variant="ghost" external>Visit villadesk.in &rarr;</Button>
        </div>
      </Card>
      <Card accent={spectrum[3]}>
        <span
          class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.12em]"
          style={`background-color:${spectrum[3]}1F;color:${spectrum[3]}`}
        >
          Services
        </span>
        <h3 class="mt-4 text-2xl">Engineering delivered for you.</h3>
        <p class="mt-3 text-[15px] leading-7 text-slate-600">
          Custom software, websites, cloud platforms, and data/AI &mdash; designed, built, shipped,
          and maintained end-to-end by a small, senior team.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href="/services" variant="secondary">Explore services</Button>
          <Button href="/work" variant="ghost">See our work &rarr;</Button>
        </div>
      </Card>
    </div>
  </Section>

  <!-- Featured product: VillaDesk -->
  <Section>
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-5">
        <p class="eyebrow">Featured product</p>
        <h2 class="mt-3 text-3xl sm:text-4xl">VillaDesk &mdash; run your villa like a hotel chain.</h2>
        <p class="mt-4 text-slate-600">
          {villadesk.summary}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={villadesk.external} external>Visit VillaDesk</Button>
          <Button href={villadesk.href} variant="secondary">Learn more</Button>
        </div>
      </div>
      <div class="lg:col-span-7">
        <div class="grid gap-4 sm:grid-cols-2">
          {
            villadeskFeatures.map((f, i) => (
              <Card accent={spectrum[i % spectrum.length]}>
                <p class="text-[15px] font-medium leading-7 text-ink">{f}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </div>
  </Section>

  <!-- What we deliver (services) -->
  <Section tone="mist">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-4">
        <p class="eyebrow">Services</p>
        <h2 class="mt-3 text-3xl sm:text-4xl">Production-grade software, across the stack.</h2>
        <p class="mt-4 text-slate-600">
          Modern web platforms, websites, cloud-native architectures, and data/AI &mdash; delivered
          as a service in its own right, or as a full-lifecycle engagement.
        </p>
        <div class="mt-6">
          <Button href="/services" variant="secondary">Explore our services</Button>
        </div>
      </div>
      <div class="lg:col-span-8">
        <div class="grid gap-6 sm:grid-cols-2">
          {
            services.map((d, i) => (
              <Card accent={spectrum[i % spectrum.length]}>
                <h3 class="text-lg">{d.title}</h3>
                <p class="mt-2 text-[15px] leading-7 text-slate-600">{d.text}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </div>
  </Section>

  <!-- At a glance -->
  <Section>
    <div class="mb-10 max-w-2xl">
      <p class="eyebrow">At a glance</p>
      <h2 class="mt-3 text-3xl sm:text-4xl">A focused team, with skin in the game.</h2>
    </div>
    <StatStrip stats={stats} />
  </Section>

  <!-- Selected work -->
  <Section tone="mist">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-2xl">
        <p class="eyebrow">Selected work</p>
        <h2 class="mt-3 text-3xl sm:text-4xl">Products and sites in production.</h2>
      </div>
      <Button href="/work" variant="secondary">See all work</Button>
    </div>
    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {
        studies.map((study, i) => (
          <CaseStudyCard
            href={`/work/${study.slug}`}
            service={study.data.service}
            title={study.data.title}
            client={study.data.client}
            summary={study.data.summary}
            outcomes={study.data.outcomes}
            accent={spectrum[i % spectrum.length]}
          />
        ))
      }
    </div>
  </Section>

  <CTABand />
</BaseLayout>
