---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page not found" description="The page you were looking for could not be found.">
  <section class="bg-white">
    <div class="wrap flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
      <p class="eyebrow">Error 404</p>
      <h1 class="mt-3 text-4xl sm:text-5xl">This page could not be found.</h1>
      <p class="mt-4 max-w-md text-slate-600">
        The page you were looking for may have moved, or never existed. Let's get you back on
        track.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/">Back to home</Button>
        <Button href="/contact" variant="secondary">Contact us</Button>
      </div>
    </div>
  </section>
</BaseLayout>
