---
import { spectrum } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CheckList from '../components/CheckList.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import CTABand from '../components/CTABand.astro';

const pillars = [
  {
    title: 'Agile delivery, adult conversations',
    items: [
      'Short iterations — typically one or two weeks — with working software at the end of each.',
      'Clear sprint goals, demo-able outcomes, and honest retrospectives.',
      'Direct access to engineers, not just project managers, throughout the engagement.',
    ],
  },
  {
    title: 'Engineering discipline',
    items: [
      'Source control, branching strategy, and code review on every change.',
      'Automated testing as a default, not an afterthought.',
      'Continuous integration and continuous delivery from day one.',
      'Documentation that future engineers — yours or ours — can actually use.',
    ],
  },
  {
    title: 'Security & compliance built-in',
    items: [
      'Secure-by-design principles applied at architecture and code level.',
      'OWASP-aligned practices, secrets management, and least-privilege access.',
      'Compliance support for GDPR, HIPAA, SOC 2, and ISO 27001 (engagement-dependent).',
    ],
  },
  {
    title: 'Communication & visibility',
    items: [
      'Shared backlog, sprint board, and status dashboard.',
      'Weekly executive update and on-demand engineering deep-dives.',
      'Defined escalation paths — you always know who to call.',
    ],
  },
];

const process = [
  {
    title: 'Discovery call',
    text: 'A 30–60 minute conversation to understand your problem, context, and goals. No cost, no obligation.',
  },
  {
    title: 'Scoping & proposal',
    text: 'Within one week, you receive a written proposal: approach, timeline, deliverables, team, and pricing.',
  },
  {
    title: 'Kick-off',
    text: 'Once we agree on scope, we kick off within days — not months — with the same senior engineers who will deliver the work.',
  },
  {
    title: 'Delivery',
    text: 'Short iterations, working software, and weekly visibility into progress and decisions.',
  },
  {
    title: 'Live and beyond',
    text: 'We support what we build and stay with the product for as long as you need us.',
  },
];
---

<BaseLayout
  title="How We Work"
  description="How LoqalAds works — agile delivery, engineering discipline, security built-in, transparent communication, and a clear path from first call to production."
>
  <PageHeader
    eyebrow="How we work"
    title="Lightweight process. Serious discipline."
    intro="Our process is intentionally lightweight, transparent, and adapted to each engagement. The principles below stay constant regardless of project size."
  />

  <Section>
    <div class="grid gap-6 lg:grid-cols-2">
      {
        pillars.map((p, i) => {
          const color = spectrum[i % spectrum.length];
          return (
            <Card accent={color}>
              <h2 class="text-xl">{p.title}</h2>
              <div class="mt-5">
                <CheckList items={p.items} color={color} />
              </div>
            </Card>
          );
        })
      }
    </div>
  </Section>

  <Section tone="mist">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-5">
        <p class="eyebrow">Getting started</p>
        <h2 class="mt-3 text-3xl sm:text-4xl">From first call to production.</h2>
        <p class="mt-4 text-slate-600">
          Engaging with us is straightforward. Most clients move from first conversation to signed
          engagement within two weeks.
        </p>
        <p class="mt-4 text-slate-600">
          Every engagement starts the same way: a free discovery conversation, followed by a
          written proposal that explains exactly what we will do, how long it will take, and what
          it will cost. No surprises.
        </p>
      </div>
      <div class="lg:col-span-7">
        <ProcessTimeline steps={process} />
      </div>
    </div>
  </Section>

  <CTABand />
</BaseLayout>
