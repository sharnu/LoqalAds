---
import { spectrum, site } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import Button from '../../components/Button.astro';

const VILLADESK = 'https://www.villadesk.in';

const features = [
  {
    title: 'WhatsApp automation',
    text: 'Confirmations, reminders, and review requests sent automatically from the owner’s own number.',
  },
  {
    title: 'UPI payment links',
    text: 'Collect advances and balances faster with one-tap UPI links — fewer no-shows, fewer awkward chases.',
  },
  {
    title: '10-stage booking pipeline',
    text: 'Track every enquiry from first message to checkout, so nothing slips through the cracks.',
  },
  {
    title: 'Smart seasonal pricing',
    text: 'Variable rates for weekends, seasons, and festivals — set once, applied automatically.',
  },
  {
    title: 'Occupancy & iCal sync',
    text: 'Two-way calendar sync with Airbnb and Booking.com to avoid double bookings.',
  },
  {
    title: 'Quotes & GST invoicing',
    text: 'Shareable quotes and compliant GST invoices generated in seconds.',
  },
  {
    title: 'Daily 8 AM briefing',
    text: 'A morning summary of check-ins, check-outs, and pending balances — straight to your phone.',
  },
  {
    title: 'Caretaker logins',
    text: 'Give caretakers access with financial figures masked, so day-to-day runs without exposing revenue.',
  },
];

const plans = [
  {
    name: 'Starter',
    monthly: '₹1,999',
    yearly: '₹1,599/mo billed yearly',
    note: 'For a single villa getting organised.',
  },
  {
    name: 'Growth',
    monthly: '₹2,999',
    yearly: '₹2,399/mo billed yearly',
    note: 'For owners scaling enquiries and bookings.',
    featured: true,
  },
  {
    name: 'Pro',
    monthly: '₹5,999',
    yearly: '₹4,799/mo billed yearly',
    note: 'For multi-property agencies and operators.',
  },
];
---

<BaseLayout
  title="VillaDesk — Guest CRM for villas & homestays"
  description="VillaDesk is a WhatsApp-assisted guest CRM built for independent villa and homestay owners in India. Capture every enquiry, automate messaging, and stop revenue leaks. A product by LoqalAds."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-line bg-white">
    <div
      class="absolute left-1/2 top-0 h-72 w-[680px] -translate-x-1/2 rounded-full bg-spectrum opacity-[0.12] blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="wrap relative py-16 text-center sm:py-20">
      <p class="eyebrow justify-center">A product by {site.name}</p>
      <h1 class="mx-auto mt-4 max-w-4xl text-4xl leading-[1.08] sm:text-5xl lg:text-6xl">
        Run your villa <span class="text-spectrum">like a hotel chain.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        VillaDesk is a WhatsApp-assisted guest CRM built only for independent villa and homestay
        owners in India — capture every enquiry, automate messaging, and stop revenue leaking to OTA
        commissions, slow replies, and uncollected balances.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href={VILLADESK} external>Start a 14-day free trial</Button>
        <Button href={VILLADESK} variant="secondary" external>Visit villadesk.in &rarr;</Button>
      </div>
      <p class="mt-6 text-sm font-medium text-slate-500">
        No credit card required &middot; Built for India &middot; WhatsApp &amp; UPI native
      </p>
    </div>
  </section>

  <!-- The problem -->
  <Section tone="mist">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow justify-center">Why it exists</p>
      <p class="mt-4 font-display text-2xl leading-relaxed text-ink sm:text-3xl">
        Independent owners lose money three ways — OTA commissions on repeat guests, enquiries that
        go cold from slow replies, and balances never collected after check-in.
      </p>
      <p class="mt-5 text-slate-600">
        VillaDesk closes all three leaks with one simple, WhatsApp-first system.
      </p>
    </div>
  </Section>

  <!-- Features -->
  <Section>
    <div class="max-w-2xl">
      <p class="eyebrow">What's inside</p>
      <h2 class="mt-3 text-3xl sm:text-4xl">Everything an owner needs, in one place.</h2>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((f, i) => {
          const color = spectrum[i % spectrum.length];
          return (
            <Card accent={color}>
              <h3 class="text-lg">{f.title}</h3>
              <p class="mt-2 text-[15px] leading-7 text-slate-600">{f.text}</p>
            </Card>
          );
        })
      }
    </div>
  </Section>

  <!-- Who it's for -->
  <Section tone="mist">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow justify-center">Who it's for</p>
      <h2 class="mt-3 text-3xl sm:text-4xl">From a single villa to fifteen.</h2>
      <p class="mt-4 text-slate-600">
        Solo villa owners, homestay hosts, multi-property agencies, and tourism operators managing
        1–15 properties across India.
      </p>
    </div>
  </Section>

  <!-- Pricing -->
  <Section>
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow justify-center">Pricing</p>
      <h2 class="mt-3 text-3xl sm:text-4xl">Simple plans, paid by UPI.</h2>
      <p class="mt-4 text-slate-600">
        Every plan starts with a 14-day free trial — no credit card required.
      </p>
    </div>
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        plans.map((p, i) => {
          const color = spectrum[i % spectrum.length];
          return (
            <Card accent={color} class={p.featured ? 'ring-2 ring-accent' : ''}>
              {p.featured && (
                <span class="inline-flex items-center rounded-full bg-accent px-3 py-1 text-xs font-bold uppercase tracking-[0.12em] text-white">
                  Most popular
                </span>
              )}
              <h3 class="mt-3 text-xl">{p.name}</h3>
              <p class="mt-3">
                <span class="font-display text-3xl font-bold text-ink">{p.monthly}</span>
                <span class="text-sm text-slate-500"> /month</span>
              </p>
              <p class="mt-1 text-sm text-slate-500">{p.yearly}</p>
              <p class="mt-4 text-[15px] leading-7 text-slate-600">{p.note}</p>
              <div class="mt-6">
                <Button href={VILLADESK} variant={p.featured ? 'primary' : 'secondary'} external>
                  Start free trial
                </Button>
              </div>
            </Card>
          );
        })
      }
    </div>
  </Section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-spectrum-diag">
    <div class="absolute -right-24 -top-28 h-72 w-72 rounded-full bg-white/15 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -bottom-28 -left-24 h-72 w-72 rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="wrap relative py-16 text-center sm:py-20">
      <h2 class="mx-auto max-w-2xl text-3xl text-white sm:text-4xl">
        See VillaDesk in action.
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-white/80">
        Visit villadesk.in to start your free trial, or talk to the LoqalAds team about a guided demo.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href={VILLADESK} variant="light" external>Visit VillaDesk</Button>
        <Button href="/contact" variant="outline">Talk to our team</Button>
      </div>
    </div>
  </section>
</BaseLayout>
