---
import { spectrum, site } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import Button from '../../components/Button.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';
import IntegrationStrip from '../../components/IntegrationStrip.astro';

const highlights = [
  {
    title: 'WhatsApp automation',
    text: 'Confirmations, reminders, and review requests — from the owner’s own number.',
  },
  {
    title: 'UPI payment links',
    text: 'Advances and balances collected on time, with one tap.',
  },
  {
    title: '10-stage pipeline',
    text: 'Every enquiry tracked from first message to checkout.',
  },
  {
    title: 'Calendar sync',
    text: 'Two-way iCal sync with Airbnb and Booking.com — no double bookings.',
  },
];

const playbook = [
  {
    title: 'We feel the problem',
    text: 'We operate VillaDesk ourselves, so we build what owners actually need — not what looks good in a demo.',
  },
  {
    title: 'India-first by design',
    text: 'WhatsApp and UPI are native, not bolted on. Built for how business really happens here.',
  },
  {
    title: 'The same craft you can hire',
    text: 'The engineering behind our products is exactly the engineering we bring to client work.',
  },
];
---

<BaseLayout
  title="Products"
  description="Products built and run by LoqalAds — including VillaDesk, a WhatsApp-assisted guest CRM for villa and homestay owners in India."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-line bg-white">
    <div
      class="absolute left-1/2 top-0 h-72 w-[680px] -translate-x-1/2 rounded-full bg-spectrum opacity-[0.12] blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="wrap relative py-16 text-center sm:py-20">
      <p class="eyebrow justify-center">Our products</p>
      <h1 class="mx-auto mt-4 max-w-3xl text-4xl leading-[1.08] sm:text-5xl lg:text-6xl">
        Software we <span class="text-spectrum">build, own, and run.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        Alongside our client services, we invest in products of our own — software we operate,
        support, and grow. Here’s what we’re building.
      </p>
    </div>
  </section>

  <!-- Flagship: VillaDesk -->
  <Section>
    <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-6">
        <div class="flex items-center gap-3">
          <span
            class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.12em]"
            style={`background-color:${spectrum[1]}1F;color:${spectrum[1]}`}
          >
            Flagship product
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-600">
            <span class="h-2 w-2 rounded-full bg-emerald-500"></span> Live
          </span>
        </div>

        <h2 class="mt-5 font-display text-4xl font-bold text-ink sm:text-5xl">VillaDesk</h2>
        <p class="mt-2 text-lg font-semibold text-slate-500">Run your villa like a hotel chain.</p>
        <p class="mt-5 text-[15px] leading-7 text-slate-600">
          A WhatsApp-assisted guest CRM built only for independent villa and homestay owners in
          India — capture every enquiry, automate messaging, and stop revenue leaking to OTA
          commissions, slow replies, and uncollected balances.
        </p>

        <div class="mt-7 grid gap-3 sm:grid-cols-2">
          {
            highlights.map((h, i) => (
              <div class="flex gap-3">
                <span
                  class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg"
                  style={`background-color:${spectrum[i % spectrum.length]}1F;color:${spectrum[i % spectrum.length]}`}
                >
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 1 1 1.4-1.4l2.8 2.8 6.8-6.8a1 1 0 0 1 1.4 0Z" />
                  </svg>
                </span>
                <div>
                  <p class="text-sm font-semibold text-ink">{h.title}</p>
                  <p class="mt-0.5 text-[13px] leading-5 text-slate-500">{h.text}</p>
                </div>
              </div>
            ))
          }
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/products/villadesk">Explore VillaDesk</Button>
          <Button href="https://www.villadesk.in" variant="secondary" external>
            Visit villadesk.in &rarr;
          </Button>
        </div>
      </div>

      <div class="lg:col-span-6">
        <PhoneMockup />
      </div>
    </div>

    <IntegrationStrip class="mt-16 border-t border-line pt-12" />
  </Section>

  <!-- Why we build products -->
  <Section tone="mist">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow justify-center">Why we build our own</p>
      <h2 class="mt-3 text-3xl sm:text-4xl">A product company, not just a vendor.</h2>
      <p class="mt-4 text-slate-600">
        Owning products keeps us honest. It is the difference between writing software and living
        with it.
      </p>
    </div>
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        playbook.map((p, i) => {
          const color = spectrum[i % spectrum.length];
          return (
            <Card accent={color}>
              <span
                class="inline-flex h-11 w-11 items-center justify-center rounded-xl font-display text-base font-bold"
                style={`background-color:${color}1F;color:${color}`}
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="mt-4 text-lg">{p.title}</h3>
              <p class="mt-2 text-[15px] leading-7 text-slate-600">{p.text}</p>
            </Card>
          );
        })
      }
    </div>
  </Section>

  <!-- What's next -->
  <Section>
    <div class="overflow-hidden rounded-2xl border border-line bg-ink px-8 py-12 text-center sm:px-12">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">More on the way</p>
      <h2 class="mx-auto mt-4 max-w-2xl text-3xl text-white sm:text-4xl">
        VillaDesk is the first of several.
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-slate-300">
        We’re building more products for the hospitality and local-business space. Have an idea, or
        want to partner with us on one? Let’s talk.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/contact" variant="light">Talk to {site.name}</Button>
        <Button href="/work" variant="outline">See our work</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
