---
import { spectrum } from '../data/site';

interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-line bg-line lg:grid-cols-4">
  {
    stats.map((s, i) => {
      const color = spectrum[i % spectrum.length];
      return (
        <div class="bg-white p-6 text-center sm:p-7">
          <div class="font-display text-3xl font-bold sm:text-4xl" style={`color:${color}`}>
            {s.value}
          </div>
          <div class="mt-2 text-sm text-slate-500">{s.label}</div>
        </div>
      );
    })
  }
</div>
