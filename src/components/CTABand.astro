---
import Button from './Button.astro';

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Let's build something excellent.",
  text = 'Every engagement starts the same way — a free discovery conversation, with no cost and no obligation.',
} = Astro.props;
---

<section class="relative overflow-hidden bg-spectrum-diag">
  <div
    class="absolute -right-24 -top-28 h-72 w-72 rounded-full bg-white/15 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute -bottom-28 -left-24 h-72 w-72 rounded-full bg-white/10 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div class="wrap relative py-16 text-center sm:py-20">
    <h2 class="mx-auto max-w-2xl text-3xl text-white sm:text-4xl">{title}</h2>
    <p class="mx-auto mt-4 max-w-xl text-white/80">{text}</p>
    <div class="mt-8 flex justify-center">
      <Button href="/contact" variant="light">Start a conversation</Button>
    </div>
  </div>
</section>
