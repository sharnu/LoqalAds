---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a
  href="/"
  class={`group inline-flex items-center gap-3 ${className}`}
  aria-label="Nexus Engineering — home"
>
  <img
    src="/nexus-logo-sm.png"
    alt=""
    width="44"
    height="44"
    class="h-11 w-11 rounded-xl ring-1 ring-line transition-transform duration-200 group-hover:scale-105"
  />
  <span class="flex flex-col leading-none">
    <span class="font-display text-base font-bold text-ink">Nexus Engineering</span>
    <span class="mt-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-slate-400">
      Software, end-to-end
    </span>
  </span>
</a>
