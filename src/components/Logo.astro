---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a
  href="/"
  class={`group inline-flex items-center gap-3 ${className}`}
  aria-label="LoqalAds — home"
>
  <img
    src="/loqalads-logo-sm.png"
    alt=""
    width="44"
    height="44"
    class="h-11 w-11 transition-transform duration-200 group-hover:scale-105"
  />
  <span class="flex flex-col leading-none">
    <span class="font-display text-base font-bold text-ink">
      Loqal<span class="text-accent">Ads</span>
    </span>
    <span class="mt-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-slate-400">
      Media Pvt Ltd · Pune
    </span>
  </span>
</a>
