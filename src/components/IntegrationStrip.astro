---
// "Works with" strip — the channels VillaDesk plugs into.
interface Props {
  heading?: string;
  class?: string;
}
const { heading = 'Works with the tools owners already use', class: className = '' } = Astro.props;
---

<div class={className}>
  <p class="text-center text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">
    {heading}
  </p>
  <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
    <!-- WhatsApp -->
    <span class="inline-flex items-center gap-2 text-ink/70">
      <svg class="h-7 w-7" viewBox="0 0 360 362" fill="none" aria-hidden="true">
        <path fill="#25D366" fill-rule="evenodd" d="M307.546 52.566C273.709 18.684 228.706.017 180.756 0 81.951 0 1.538 80.404 1.504 179.235c-.017 31.594 8.242 62.432 23.928 89.609L0 361.736l95.024-24.925c26.179 14.285 55.659 21.805 85.655 21.814h.077c98.788 0 179.21-80.413 179.244-179.244.017-47.898-18.608-92.926-52.454-126.807v-.008Zm-126.79 275.788h-.06c-26.73-.008-52.952-7.194-75.831-20.765l-5.44-3.231-56.391 14.791 15.05-54.981-3.542-5.638c-14.912-23.721-22.793-51.139-22.776-79.286.035-82.14 66.867-148.973 149.051-148.973 39.793.017 77.198 15.53 105.328 43.695 28.131 28.157 43.61 65.596 43.593 105.398-.035 82.149-66.867 148.982-148.982 148.982v.008Zm81.719-111.577c-4.478-2.243-26.497-13.073-30.606-14.568-4.108-1.496-7.09-2.243-10.073 2.243-2.982 4.487-11.568 14.577-14.181 17.559-2.613 2.991-5.226 3.361-9.704 1.117-4.477-2.243-18.908-6.97-36.02-22.226-13.313-11.878-22.304-26.54-24.916-31.027-2.613-4.486-.275-6.91 1.959-9.136 2.011-2.011 4.478-5.234 6.721-7.847 2.244-2.613 2.983-4.486 4.478-7.469 1.496-2.991.748-5.603-.369-7.847-1.118-2.243-10.073-24.289-13.812-33.253-3.636-8.732-7.331-7.546-10.073-7.692-2.613-.13-5.595-.155-8.586-.155-2.991 0-7.839 1.118-11.947 5.604-4.108 4.486-15.677 15.324-15.677 37.361s16.047 43.344 18.29 46.335c2.243 2.991 31.585 48.225 76.51 67.632 10.684 4.615 19.029 7.374 25.535 9.437 10.727 3.412 20.49 2.931 28.208 1.779 8.604-1.289 26.498-10.838 30.228-21.298 3.73-10.46 3.73-19.433 2.613-21.298-1.117-1.865-4.108-2.991-8.586-5.234l.008-.017Z" clip-rule="evenodd" />
      </svg>
      <span class="font-display text-sm font-semibold">WhatsApp</span>
    </span>

    <!-- Airbnb -->
    <span class="inline-flex items-center gap-2 text-ink/70">
      <svg class="h-7 w-7" viewBox="0 0 1991.3 2143.2" aria-hidden="true">
        <path fill="#FF5A5F" d="m1851.6 1735.6c-15 111.6-90.1 208.1-195.2 251-51.5 21.4-107.3 27.9-163.1 21.4-53.6-6.4-107.3-23.6-163-55.7-77.2-43-154.5-109.4-244.6-208.1 141.6-173.8 227.4-332.5 259.6-474.1 15-66.5 17.2-126.6 10.7-182.4-8.6-53.6-27.9-103-57.9-145.9-66.5-96.5-178.1-152.3-302.5-152.3s-236 57.9-302.5 152.3c-30 42.9-49.3 92.3-57.9 145.9-8.6 55.8-6.4 118 10.7 182.4 32.2 141.6 120.1 302.5 259.6 476.2-88 98.7-167.3 165.2-244.6 208.1-55.8 32.2-109.4 49.4-163 55.8-55.3 6.2-111.2-1.2-163-21.4-105.1-42.9-180.2-139.5-195.2-251-6.4-53.6-2.1-107.2 19.3-167.3 6.4-21.5 17.2-42.9 27.9-68.6 15-34.3 32.2-70.8 49.3-107.3l2.2-4.3c148-319.7 306.8-645.8 472-963.3l6.4-12.9c17.2-32.1 34.3-66.5 51.5-98.7 17.2-34.3 36.5-66.5 60.1-94.4 45.1-51.5 105.1-79.4 171.6-79.4s126.6 27.9 171.6 79.4c23.6 27.9 42.9 60.1 60.1 94.4 17.2 32.2 34.3 66.5 51.5 98.6l6.5 12.9c163 319.6 321.8 645.7 469.8 965.4v2.1c17.2 34.3 32.2 73 49.3 107.3 10.7 25.8 21.5 47.2 27.9 68.6 17.1 55.9 23.5 109.5 14.9 165.3zm-856-100.9c-115.8-145.9-190.9-283.2-216.7-399-10.7-49.4-12.9-92.3-6.4-130.9 4.3-34.3 17.2-64.4 34.3-90.1 40.8-57.9 109.4-94.4 188.8-94.4s150.2 34.4 188.8 94.4c17.2 25.8 30 55.8 34.3 90.1 6.4 38.6 4.3 83.7-6.4 130.9-25.7 113.7-100.8 251-216.7 399z" />
      </svg>
      <span class="font-display text-sm font-semibold">Airbnb</span>
    </span>

    <!-- Booking.com -->
    <span class="inline-flex items-center gap-2 text-ink/70">
      <span class="flex h-7 w-7 items-center justify-center rounded-md bg-[#003580] font-display text-sm font-bold text-white">B.</span>
      <span class="font-display text-sm font-semibold">Booking.com</span>
    </span>

    <!-- UPI -->
    <span class="inline-flex items-center gap-2 text-ink/70">
      <span class="flex h-7 items-center gap-0.5 rounded-md px-1.5 font-display text-sm font-bold ring-1 ring-line">
        <span class="text-[#097939]">U</span><span class="text-[#ED752E]">P</span><span class="text-[#097939]">I</span>
      </span>
      <span class="font-display text-sm font-semibold">UPI Payments</span>
    </span>

    <!-- GST -->
    <span class="inline-flex items-center gap-2 text-ink/70">
      <span class="flex h-7 items-center rounded-md bg-mist px-2 font-display text-xs font-bold text-ink ring-1 ring-line">GST</span>
      <span class="font-display text-sm font-semibold">Invoicing</span>
    </span>
  </div>
</div>
