---
interface Props {
  href: string;
  service: string;
  title: string;
  client: string;
  summary: string;
  outcomes: string[];
  accent?: string;
}

const { href, service, title, client, summary, outcomes, accent = '#1E80FF' } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-xl border border-line bg-white shadow-card transition-all duration-200 hover:-translate-y-0.5 hover:shadow-glow"
>
  <div class="h-1.5 w-full" style={`background-color:${accent}`}></div>
  <div class="flex flex-col p-7">
    <span
      class="inline-flex w-fit items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.12em]"
      style={`background-color:${accent}1F;color:${accent}`}
    >
      {service}
    </span>
    <h3 class="mt-4 text-xl transition-colors group-hover:text-accent">{title}</h3>
    <p class="mt-1.5 text-sm font-semibold text-slate-500">{client}</p>
    <p class="mt-4 text-[15px] leading-7 text-slate-600">{summary}</p>

    <ul class="mt-6 space-y-2.5 border-t border-line pt-6">
      {
        outcomes.map((o) => (
          <li class="flex gap-2.5 text-sm font-semibold text-ink">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0"
              style={`color:${accent}`}
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 1 1 1.4-1.4l2.8 2.8 6.8-6.8a1 1 0 0 1 1.4 0Z" />
            </svg>
            <span>{o}</span>
          </li>
        ))
      }
    </ul>

    <span class="mt-6 text-sm font-bold text-accent">Read the engagement &rarr;</span>
  </div>
</a>
