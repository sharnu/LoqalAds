---
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<section class="border-b border-line bg-mist">
  <div class="wrap py-16 sm:py-20 lg:py-24">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="mt-3 max-w-3xl text-4xl leading-tight sm:text-5xl">{title}</h1>
    {intro && <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-600">{intro}</p>}
  </div>
</section>
