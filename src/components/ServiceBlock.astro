---
interface Props {
  number: string;
  title: string;
  summary: string;
  deliverables?: string;
  color?: string;
  id?: string;
}

const { number, title, summary, deliverables, color = '#4F46E5', id } = Astro.props;
---

<div id={id} class="grid gap-6 border-t border-line py-10 lg:grid-cols-12 lg:gap-10">
  <div class="lg:col-span-4">
    <span
      class="inline-flex h-12 w-12 items-center justify-center rounded-xl font-display text-base font-bold"
      style={`background-color:${color}1F;color:${color}`}
    >
      {number}
    </span>
    <h3 class="mt-4 text-2xl">{title}</h3>
    <p class="mt-3 text-[15px] leading-7 text-slate-600">{summary}</p>
  </div>
  <div class="lg:col-span-8">
    <slot />
    {
      deliverables && (
        <p
          class="mt-6 rounded-lg border-l-4 bg-mist p-4 text-sm leading-6 text-slate-600"
          style={`border-color:${color}`}
        >
          <span class="font-semibold text-ink">Deliverables — </span>
          {deliverables}
        </p>
      )
    }
  </div>
</div>
