---
interface Props {
  items: string[];
  heading?: string;
  class?: string;
  color?: string;
}

const { items, heading, class: className = '', color } = Astro.props;
---

<div class={className}>
  {
    heading && (
      <h4 class="mb-3 text-xs font-bold uppercase tracking-[0.14em] text-ink">{heading}</h4>
    )
  }
  <ul class="space-y-2.5">
    {
      items.map((item) => (
        <li class="flex gap-3 text-[15px] leading-6 text-slate-600">
          <svg
            class={`mt-0.5 h-4 w-4 shrink-0 ${color ? '' : 'text-accent'}`}
            style={color ? `color:${color}` : undefined}
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 1 1 1.4-1.4l2.8 2.8 6.8-6.8a1 1 0 0 1 1.4 0Z" />
          </svg>
          <span set:html={item} />
        </li>
      ))
    }
  </ul>
</div>
